# ─────────────────────────────────────────
# Auth Service Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ─────────────────────────────────────────

NODE_ENV=development
SERVICE_NAME=auth-service
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://admin:admin123@localhost:5432/cricket_db

# Redis (token blacklist, rate limiting)
REDIS_URL=redis://:redis123@localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Password Reset
RESET_TOKEN_EXPIRY_SECONDS=3600

# Email (NodeMailer — use SMTP or service like SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@cricket-cms.com

# Rate Limiting
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
