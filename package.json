{
  "name": "cricket-cms",
  "version": "1.0.0",
  "description": "Cricket Management System - Microservice Backend",
  "private": true,
  "workspaces": [
    "shared",
    "services/*",
    "api-gateway"
  ],
  "scripts": {
  "dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
  "dev:infra": "docker compose up postgres mongodb redis rabbitmq minio -d",
  "dev:down": "docker compose down",
  "dev:clean": "docker compose down -v --remove-orphans",
  
  "lint": "eslint 'services/*/src/**/*.js' 'shared/src/**/*.js' 'api-gateway/src/**/*.js'",
  "lint:fix": "eslint --fix 'services/*/src/**/*.js' 'shared/src/**/*.js' 'api-gateway/src/**/*.js'",
  "format": "prettier --write 'services/*/src/**/*.js' 'shared/src/**/*.js' 'api-gateway/src/**/*.js'",
  
  "test": "jest --runInBand",
  "test:coverage": "jest --coverage --runInBand",
  
  "migrate": "node scripts/migrate.js",
  "seed": "node scripts/seed.js",
  "health": "node scripts/health-check.js"
},
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-node": "^11.1.0",
    "prettier": "^3.2.5",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
